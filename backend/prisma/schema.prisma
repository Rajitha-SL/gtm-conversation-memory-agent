datasource db {
  provider = "postgresql"
} 

generator client {
  provider = "prisma-client-js"
}

model CallSummary {
  id              String   @id @default(uuid())
  callId          String   @unique
  rawTranscript   String
  aiAnalysisPass  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}